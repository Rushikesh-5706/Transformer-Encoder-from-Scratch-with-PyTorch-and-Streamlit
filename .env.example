# Environment variables for the Transformer Encoder project.
# Copy this file to .env and populate values before running.

# Set to 'cpu' to force CPU-only training if no GPU is available.
# Set to 'cuda' to use GPU if available.
DEVICE=cpu

# Number of training epochs. Minimum 15 for meaningful entropy logs.
NUM_EPOCHS=15

# Batch size for training.
BATCH_SIZE=32

# Maximum vocabulary size.
MAX_VOCAB_SIZE=10000
